# =========================
# Terraform
# =========================

# Local provider plugin cache and init artifacts - regenerated by `terraform init`, no need to track
**/.terraform/*
.terraform.d/

# State files - contain full resource attributes, often including secrets in plaintext
*.tfstate
*.tfstate.*
*.tfstate.backup

# Variable files - typically hold real subscription IDs, IPs, passwords, connection strings
*.tfvars
*.tfvars.json
# Exception: keep the example file with placeholder values so others can clone and adapt it
!terraform.tfvars.example

# Crash/debug logs - can leak resource details from a failed run
crash.log
crash.*.log

# Local override files - meant for personal/local testing, not shared config
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files - binary plan can contain sensitive diffs of your infrastructure
*.tfplan
*tfplan*

# CLI config files - may reference local credentials or backend tokens
.terraformrc
terraform.rc

# Terragrunt cache, if used - same rationale as .terraform/
.terragrunt-cache/

# =========================
# Vagrant
# =========================

# Local VM state, box metadata, SSH keys for the running VM - machine-specific, not portable
.vagrant/

# Retry files from failed Ansible provisioning triggered via Vagrant - local debug artifact only
*.retry

# =========================
# Ansible
# =========================

# Vault-encrypted secrets files - even encrypted, avoid committing unless intentionally versioned
*.vault.yml
vault_pass.txt
.vault_pass

# Retry files - local-only record of failed hosts, regenerated each run
*.retry

# Local inventory overrides - often contain real IPs/hostnames for your specific lab
inventory/local
hosts.local

# =========================
# Azure
# =========================

# Azure CLI local config/cache - may cache tokens or subscription context tied to your machine
.azure/

# Service principal / credential exports - never commit auth material
*.azureauth
*.pem
*.key

# Azure Migrate appliance logs - can contain discovered on-prem inventory/network details
*.appliance.log

# =========================
# General secrets / environment
# =========================

# Local env var files - used to inject secrets via TF_VAR_ or ANSIBLE_ vars, never shared
.env
.env.local

# OS/editor noise - unrelated to security, just repo hygiene
.DS_Store
.vscode/
.idea/
