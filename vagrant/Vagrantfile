# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# =============================================================================
# Vagrantfile - onprem-to-azure-migration lab
# =============================================================================
# Defines two VMs that model a small on-prem environment prior to migration:
#   1. ad-dc     - Windows Server domain controller + DNS
#   2. rhel-app  - RHEL application server
#
# All host-specific values (IPs, memory, CPU, box versions) live in
# config.yml / config.example.yml, NOT in this file. This file should not
# need to be edited by someone cloning the repo - only the config file.
#
# PREREQUISITES:
#   - Vagrant installed
#   - VirtualBox installed
#   - config.yml created from config.example.yml (see that file's header)
#
# USAGE:
#   vagrant up ad-dc        # bring up the Windows DC first (test in isolation)
#   vagrant up rhel-app     # bring up the RHEL app server
#   vagrant up              # bring up both machines together
#   vagrant ssh rhel-app    # SSH into the Linux box
#   vagrant rdp ad-dc       # RDP into the Windows box (if rdp plugin installed)
# =============================================================================

require 'yaml'

# -----------------------------------------------------------------------------
# Load configuration
# -----------------------------------------------------------------------------
# Prefer the real config.yml (gitignored, contains your actual values).
# Fall back to the example file so a fresh clone works with zero setup.
CONFIG_FILE = File.exist?('config.yml') ? 'config.yml' : 'config.example.yml'
settings = YAML.load_file(CONFIG_FILE)

Vagrant.configure("2") do |config|

  # ===========================================================================
  # Machine 1: Active Directory Domain Controller / DNS (Windows Server)
  # ===========================================================================
  config.vm.define "ad-dc" do |ad|

    # --- Box selection ---
    # Box name/version come from config so this can be swapped without
    # touching this file (e.g. to a Desktop Experience variant later).
    ad.vm.box         = settings['ad_vm']['box']
    ad.vm.box_version = settings['ad_vm']['box_version']
    ad.vm.hostname    = settings['ad_vm']['hostname']

    # --- Communicator ---
    # Windows guests use WinRM instead of SSH for Vagrant's control channel.
    # Without this, Vagrant defaults to SSH and provisioning will fail.
    ad.vm.communicator = "winrm"

    # --- Networking ---
    # Adapter 1 (NAT): attached automatically by Vagrant, not defined here.
    #   -> Gives this VM outbound internet access (Windows Update, etc.)
    #      without exposing it to the physical LAN.
    # Adapter 2 (private_network, defined below): host-only network shared
    #   with rhel-app, using a STATIC IP so DNS/AD traffic between VMs is
    #   predictable and doesn't depend on DHCP lease timing.
    ad.vm.network "private_network",
      ip: settings['ad_vm']['private_ip']

    # --- Provider-specific resource limits ---
    ad.vm.provider "virtualbox" do |vb|
      vb.name   = settings['ad_vm']['hostname']  # Friendly name in the VirtualBox GUI
      vb.memory = settings['ad_vm']['memory']    # RAM in MB, sized for AD DS + DNS + GUI console overhead
      vb.cpus   = settings['ad_vm']['cpus']      # vCPU count
      vb.gui    = true                           # Enables a GUI for the host rather then running headless
      vb.customize ["modifyvm", :id, "--groups", "/onprem-to-azure-lab"] # Groups VM under one folder in VirtualBox GUI
    end
  end

  # ===========================================================================
  # Machine 2: RHEL Application Server
  # ===========================================================================
  config.vm.define "rhel-app" do |app|

    # --- Box selection ---
    app.vm.box         = settings['rhel_vm']['box']
    app.vm.box_version = settings['rhel_vm']['box_version']
    app.vm.hostname    = settings['rhel_vm']['hostname']

    # --- Networking ---
    # Same pattern as ad-dc: NAT adapter (auto) for internet, private_network
    # (below) with a static IP for lab-internal traffic and Ansible control.
    app.vm.network "private_network",
      ip: settings['rhel_vm']['private_ip']

    # --- Provider-specific resource limits ---
    app.vm.provider "virtualbox" do |vb|
      vb.name   = settings['rhel_vm']['hostname']
      vb.memory = settings['rhel_vm']['memory']  # RAM in MB, sized for minimal RHEL install + Ansible/Python runtime
      vb.cpus   = settings['rhel_vm']['cpus']
      vb.gui    = true                           # Enables a GUI for the host rather then running headless
      vb.customize ["modifyvm", :id, "--groups", "/onprem-to-azure-lab"] # Groups VM under one folder in VirtualBox GUI
    end

    # --- Baseline provisioning (minimal - full config lives in Ansible) ---
    app.vm.provision "shell", inline: <<-SHELL
      timedatectl set-ntp true   # Ensures time sync is enabled on first boot, prevents Kerberos clock-skew issues later
    SHELL

  end

 end
