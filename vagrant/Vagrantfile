# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# =============================================================================
# Vagrantfile - onprem-to-azure-migration lab
# =============================================================================
# Defines two VMs modeling a small on-prem environment prior to migration:
#   1. ad-dc     - Windows Server domain controller + DNS
#   2. rhel-app  - RHEL application server
#
# All host-specific values (IPs, memory, CPU, box versions, AD names) live in
# config.yml / config.example.yml, NOT in this file. Cloning this repo should
# only ever require editing the config file, never this Vagrantfile.
#
# PREREQUISITES:
#   - Vagrant installed
#   - VirtualBox installed
#   - config.yml created from config.example.yml (see that file's header)
#
# USAGE:
#   vagrant up ad-dc        # bring up the Windows DC first (test in isolation)
#   vagrant up rhel-app     # bring up the RHEL app server
#   vagrant up              # bring up both machines together
#   vagrant ssh rhel-app    # SSH into the Linux box
#   vagrant rdp ad-dc       # RDP into the Windows box (if rdp plugin installed)
# =============================================================================

require 'yaml'

# Prefer real config.yml (gitignored, real values). Fall back to the example
# file so a fresh clone still runs with zero setup.
CONFIG_FILE = File.exist?('config.yml') ? 'config.yml' : 'config.example.yml'
settings = YAML.load_file(CONFIG_FILE)

Vagrant.configure("2") do |config|

  # ===========================================================================
  # Machine 1: Active Directory Domain Controller / DNS (Windows Server)
  # ===========================================================================
  config.vm.define "ad-dc" do |ad|

    ad.vm.box         = settings['ad_vm']['box']
    ad.vm.box_version = settings['ad_vm']['box_version']
    ad.vm.hostname    = settings['ad_vm']['hostname']

    # Windows guests use WinRM instead of SSH for Vagrant's control channel;
    # without this, Vagrant defaults to SSH and provisioning fails.
    ad.vm.communicator = "winrm"

    # Adapter 1 (NAT, auto-attached by Vagrant): outbound internet access
    # without exposing the VM to the physical LAN.
    # Adapter 2 (below): host-only network shared with rhel-app, static IP
    # so AD/DNS traffic between VMs doesn't depend on DHCP lease timing.
    ad.vm.network "private_network",
      ip: settings['ad_vm']['private_ip']

    ad.vm.provider "virtualbox" do |vb|
      vb.name   = settings['ad_vm']['hostname']
      vb.memory = settings['ad_vm']['memory']  # Sized for AD DS + DNS + console overhead
      vb.cpus   = settings['ad_vm']['cpus']
      vb.gui    = true                         # GUI console needed to validate DC promotion (see provisioner note below)
      vb.customize ["modifyvm", :id, "--groups", "/onprem-to-azure-lab"]
    end

    # DSRM (Directory Services Restore Mode) password is intentionally never
    # stored in config.yml or any tracked file. If AD_SAFEMODE_PWD is unset,
    # a random one-time password is generated here and used only in-memory
    # for this provisioning run.
    safemode_pwd = ENV['AD_SAFEMODE_PWD'] || (0...20).map { (33 + rand(94)).chr }.join

    # install-adds.ps1 installs AD DS + DNS roles and promotes this VM to a
    # domain controller. NOTE: promotion requires a reboot to fully take
    # effect (-NoRebootOnCompletion is set in the script). Vagrant's WinRM
    # channel can fail to reconnect immediately after that reboot; if
    # `vagrant up` errors out here, reboot manually via the VirtualBox GUI
    # console and re-run Get-ADDomain/dcdiag to confirm promotion completed.
    ad.vm.provision "shell", path: "provision/install-adds.ps1",
      args: [settings['ad_vm']['ad_domain_name'], settings['ad_vm']['ad_netbios_name'], safemode_pwd]

    # Persists the ICMP allow rule that was applied manually via `vagrant
    # winrm` during KAN-3. Scoped to rhel-app's IP specifically, sourced from
    # config rather than hardcoded, so cross-VM ping validation survives a
    # `vagrant destroy` / `vagrant up` cycle without manual intervention.
    ad.vm.provision "shell", path: "provision/allow-icmp.ps1",
      args: [settings['rhel_vm']['private_ip']]
  end

  # ===========================================================================
  # Machine 2: RHEL Application Server
  # ===========================================================================
  config.vm.define "rhel-app" do |app|

    app.vm.box         = settings['rhel_vm']['box']
    app.vm.box_version = settings['rhel_vm']['box_version']
    app.vm.hostname    = settings['rhel_vm']['hostname']

    # Same pattern as ad-dc: NAT (auto) for internet, private_network below
    # with a static IP for lab-internal traffic and future Ansible control.
    app.vm.network "private_network",
      ip: settings['rhel_vm']['private_ip']

    app.vm.provider "virtualbox" do |vb|
      vb.name   = settings['rhel_vm']['hostname']
      vb.memory = settings['rhel_vm']['memory']  # Minimal RHEL install + Ansible/Python runtime headroom
      vb.cpus   = settings['rhel_vm']['cpus']
      vb.customize ["modifyvm", :id, "--groups", "/onprem-to-azure-lab"]
    end

    # Minimal baseline only - full config lives in Ansible (KAN-6+).
    app.vm.provision "shell", inline: <<-SHELL
      timedatectl set-ntp true   # Prevents Kerberos clock-skew issues once domain-joined
    SHELL
  end

end